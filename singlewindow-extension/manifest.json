{
  "manifest_version": 3,
  "name": "SingleWindow.uz AutoFill",
  "version": "1.0",
  "description": "Автоматически заполняет формы экспорта на singlewindow.uz",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "*://*.singlewindow.uz/*", 
    "*://singlewindow.uz/*",
    "http://localhost/*",
    "https://*.prodeklarant.uz/*",
    "https://prodeklarant.uz/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Заполнить форму"
  },
  "content_scripts": [
    {
      "matches": ["*://*.singlewindow.uz/*", "*://singlewindow.uz/*"],
      "js": ["content.js"]
    }
  ]
}

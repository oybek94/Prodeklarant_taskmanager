{
  "manifest_version": 3,
  "name": "Fito to'ldirgich",
  "version": "1.0",
  "description": "Автоматически заполняет формы экспорта на singlewindow.uz",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "*://*.singlewindow.uz/*", 
    "*://singlewindow.uz/*",
    "http://localhost/*",
    "https://*.prodeklarant.uz/*",
    "https://prodeklarant.uz/*"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html",
    "default_title": "Заполнить форму"
  },
  "content_scripts": [
    {
      "matches": ["*://*.singlewindow.uz/*", "*://singlewindow.uz/*"],
      "js": ["content.js"]
    }
  ]
}
